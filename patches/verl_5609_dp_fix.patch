# veRL PR #5609 — fix DP>1 hang with dense-model vLLM rollout (0.7.0 variant).
#
# Upstream bug: `verl/workers/rollout/vllm_rollout/vllm_async_server.py` gates
# DP-arg propagation to vLLM on `expert_parallel_size > 1`. For dense models
# (EP=1), DP config never reaches vLLM, so with data_parallel_size>1 the rollout
# workers deadlock at `init_device` (rank 0 waits in `init_world_group` for a
# peer that never spawns). Fix: change guard to `data_parallel_size > 1`, and
# emit `enable_expert_parallel` unconditionally after the block.
#
# Upstream PR:    https://github.com/verl-project/verl/pull/5609
# Upstream issue: https://github.com/verl-project/verl/issues/5607
#
# This patch is adapted from PR #5609 to match the 0.7.0 source layout (which
# uses `self._master_port` instead of main's `self._dp_rpc_port`). Applies to
# both 0.7.0 and 0.7.1 wheels — both ship the same bug.
#
# Apply via: ./scripts/patch_verl.sh  (idempotent)

--- a/verl/workers/rollout/vllm_rollout/vllm_async_server.py
+++ b/verl/workers/rollout/vllm_rollout/vllm_async_server.py
@@ -324,26 +324,27 @@
                     served_model_name = served_model_name.split("/")[-1]
                 args["served_model_name"] = served_model_name
 
-        if self.config.expert_parallel_size > 1:
+        if self.config.data_parallel_size > 1:
             assert self.gpus_per_node % self.config.tensor_model_parallel_size == 0, (
                 "gpus_per_node should be divisible by tensor_model_parallel_size"
             )
             data_parallel_size_local = self.gpus_per_node // self.config.tensor_model_parallel_size
             assert len(self.workers) == data_parallel_size_local * self.config.tensor_model_parallel_size, (
                 f"num workers ({len(self.workers)}) should be equal to dp_size_local "
             )
             f"({data_parallel_size_local}) * tp_size ({self.config.tensor_model_parallel_size})"
 
             args.update(
                 {
-                    "enable_expert_parallel": self.config.expert_parallel_size > 1,
                     "data_parallel_size": self.config.data_parallel_size,
                     "data_parallel_size_local": data_parallel_size_local,
                     "data_parallel_start_rank": self.node_rank * data_parallel_size_local,
                     "data_parallel_address": self._master_address,
                     "data_parallel_rpc_port": self._master_port,
                 }
             )
+
+        args.update({"enable_expert_parallel": self.config.expert_parallel_size > 1})
 
         # update lora-related args
         if self.model_config.lora_rank > 0:
