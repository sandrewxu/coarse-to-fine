# Copy this file to `.env` and fill in your credentials. `.env` is gitignored.
# On HPC, environment variables set by the job scheduler take precedence.

# ── Weights & Biases ──────────────────────────────────────────────────────────
# Required for W&B logging (steps 4, 6, 7). Get from https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=coarse-to-fine
WANDB_ENTITY=

# ── OpenAI Batch API (steps 1–2) ──────────────────────────────────────────────
# At least one of these is required to submit batch jobs for latent generation.
OPENAI_API_KEY=
OPENAI_API_KEY_YALE=
OPENAI_API_KEY_PERSONAL=

# ── Hugging Face (gated models, e.g. Qwen3) ───────────────────────────────────
HF_TOKEN=
